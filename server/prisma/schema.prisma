// CCorp SIRTS – Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SOC_LEAD
  ANALYST
  VIEWER
}

enum Category {
  PHISHING
  MALWARE
  UNAUTHORIZED_ACCESS
  DDoS
  DATA_BREACH
  INSIDER_THREAT
  OTHER
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Status {
  OPEN
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(ANALYST)
  createdAt    DateTime   @default(now())

  assignedIncidents Incident[] @relation("AssignedTo")
  createdIncidents  Incident[] @relation("CreatedBy")
  auditLogs         AuditLog[]
  comments          Comment[]

  @@map("users")
}

model Incident {
  id            String    @id @default(cuid())
  title         String
  description   String
  category      Category
  severity      Severity
  status        Status    @default(OPEN)
  sourceIP      String?
  affectedAsset String?
  assignedToId  String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  resolvedAt    DateTime?

  assignedTo User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy  User      @relation("CreatedBy", fields: [createdById], references: [id])
  auditLogs  AuditLog[]
  comments   Comment[]

  @@map("incidents")
}

model AuditLog {
  id         String   @id @default(cuid())
  incidentId String
  userId     String
  action     String
  details    String?
  timestamp  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Comment {
  id         String   @id @default(cuid())
  incidentId String
  userId     String
  body       String
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("comments")
}
