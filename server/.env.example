# CCorp SIRTS - Server Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/ccorp_sirts"

# JWT secret key - use a long random string in production
JWT_SECRET="change-this-to-a-random-secret-at-least-32-chars"

# JWT token expiry
JWT_EXPIRES_IN="7d"

# Server port
PORT=5000

# CORS origin (frontend URL)
CORS_ORIGIN="http://localhost:5173"

# Node environment
NODE_ENV=development
